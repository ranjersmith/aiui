# ── Model Configuration ──────────────────────────────────────────────
# Change these two values to swap models across the entire stack.
# Shell scripts source this file; docker-compose reads it automatically.
CHAT_MODEL=Qwen3-1.7B-Q8_0.gguf
CODER_MODEL=Qwen2.5-Coder-14B-Instruct-Q8_0.gguf
MODEL_DIR=/home/ra/models
LLAMA_SERVER_BIN=/home/ra/qwen3vl-rocm-reference/llama.cpp/build/bin/llama-server

# ── External Services ───────────────────────────────────────────────
AI_NEWS_API_KEY=
AI_NEWS_AUTH_HEADER=x-api-key
AI_NEWS_AUTH_SCHEME=
IMAGE_GEN_BASE_URL=http://192.168.50.7:8008
IMAGE_GEN_DEFAULT_ENGINE=qwen
PARKER_BASE_URL=http://192.168.50.175:8086
PARKER_DEFAULT_CORPUS_LIMIT=8
PARKER_DEFAULT_RERANK=true
